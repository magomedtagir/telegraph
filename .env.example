# Скопируйте в .env и заполните

# НОВЫЙ токен бота — старый засвечен в экспорте n8n, смените через @BotFather (/revoke)
BOT_TOKEN=8698609128:AAHlr9VWCnPGocULQo7tRmFSNCYjx7esaB8

# OAuth-токен Яндекс.Диска (как получить — см. README, раздел 1)
YANDEX_OAUTH_TOKEN=y0__wgBEIT4xoAIGPqhPSCOzaCcGDDA_aeHCI_bkpQUC5J1Z5mgiqNASkcKprPv

# Путь к файлу каталога на Диске
YANDEX_DISK_PATH=/bot-data/phone.json

# Телефон менеджера (показывается в карточке и используется для WhatsApp)
MANAGER_PHONE=+79285024111

# Сколько секунд держать каталог в кэше перед повторным скачиванием с Диска
CACHE_TTL_SECONDS=300

# Необязательно: chat_id, которому разрешена команда /reload (пусто = разрешена всем)
ADMIN_CHAT_ID=

# Обязательная подписка на канал: @username канала. Пусто — проверка выключена.
# Бот должен быть АДМИНИСТРАТОРОМ этого канала, иначе не сможет проверять подписку.
# Для приватного канала: REQUIRED_CHANNEL=-100xxxxxxxxxx (числовой id) и CHANNEL_URL=ссылка-приглашение
REQUIRED_CHANNEL=
CHANNEL_URL=
