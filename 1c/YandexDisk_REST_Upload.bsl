// Выгрузка файла на Яндекс Диск через REST API (замена WebDAV, который стал платным).
// REST API бесплатен, авторизация — OAuth-токен вместо логина/пароля приложения.
//
// Куда вставить: в общий модуль (например, ТФ_ОбщегоНазначения) вместо процедуры
// выгрузки по WebDAV. В регламентном задании заменить вызов на:
//
//     ВыгрузитьНаЯндексДискREST(СтрокаJSON, "/bot-data/phone.json", OAuthТокен);
//
// Как получить OAuth-токен — см. README бота, раздел 1.
// Папка на Диске (/bot-data) должна существовать — создайте один раз в веб-интерфейсе.

Процедура ВыгрузитьНаЯндексДискREST(Знач СтрокаJSON, Знач ПутьНаДиске, Знач OAuthТокен) Экспорт

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Authorization", "OAuth " + OAuthТокен);
	Заголовки.Вставить("Accept", "application/json");

	// --- Шаг 1: получить временный URL для загрузки ---
	Ресурс = "/v1/disk/resources/upload?path="
		+ КодироватьСтроку(ПутьНаДиске, СпособКодированияСтроки.КодировкаURL)
		+ "&overwrite=true";

	Соединение = Новый HTTPСоединение("cloud-api.yandex.net", 443, , , , 30,
		Новый ЗащищенноеСоединениеOpenSSL);

	Ответ = Соединение.Получить(Новый HTTPЗапрос(Ресурс, Заголовки));

	Если Ответ.КодСостояния = 401 Тогда
		ВызватьИсключение "Яндекс Диск: неверный или истёкший OAuth-токен (401). Получите новый токен.";
	ИначеЕсли Ответ.КодСостояния = 404 Тогда
		ВызватьИсключение "Яндекс Диск: папка не найдена (404). Создайте папку " + ПутьНаДиске + " на Диске.";
	ИначеЕсли Ответ.КодСостояния <> 200 Тогда
		ВызватьИсключение "Яндекс Диск: не удалось получить ссылку загрузки. Код "
			+ Ответ.КодСостояния + ": " + Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	ОтветСтруктура = ПрочитатьJSON(ЧтениеJSON);
	Href = ОтветСтруктура.href;

	// --- Шаг 2: разобрать href (вида https://uploaderXX.disk.yandex.net:443/upload-target/...) ---
	БезСхемы = СтрЗаменить(Href, "https://", "");
	ПозицияСлеша = СтрНайти(БезСхемы, "/");
	ХостИПорт = Лев(БезСхемы, ПозицияСлеша - 1);
	РесурсЗагрузки = Сред(БезСхемы, ПозицияСлеша);

	Порт = 443;
	Хост = ХостИПорт;
	Если СтрНайти(ХостИПорт, ":") > 0 Тогда
		Части = СтрРазделить(ХостИПорт, ":");
		Хост = Части[0];
		Порт = Число(Части[1]);
	КонецЕсли;

	// --- Шаг 3: PUT файла по полученному URL (авторизация тут не нужна) ---
	ЗапросЗагрузки = Новый HTTPЗапрос(РесурсЗагрузки);
	ЗапросЗагрузки.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8,
		ИспользованиеByteOrderMark.НеИспользовать);

	СоединениеЗагрузки = Новый HTTPСоединение(Хост, Порт, , , , 60,
		Новый ЗащищенноеСоединениеOpenSSL);

	ОтветЗагрузки = СоединениеЗагрузки.ВызватьHTTPМетод("PUT", ЗапросЗагрузки);

	Если ОтветЗагрузки.КодСостояния <> 201 И ОтветЗагрузки.КодСостояния <> 202 Тогда
		ВызватьИсключение "Яндекс Диск: ошибка загрузки файла. Код " + ОтветЗагрузки.КодСостояния;
	КонецЕсли;

КонецПроцедуры
